# Copy to infra/.env on the host and fill in. infra/.env is git-ignored.

# --- Domain / TLS ---
DOMAIN=gulp.example.com
ACME_EMAIL=you@example.com            # Let's Encrypt account (recommended)

# --- Postgres (password must match DATABASE_URL) ---
POSTGRES_PASSWORD=change-me-strong
DATABASE_URL=postgresql+psycopg://gulp:change-me-strong@db:5432/gulp

# --- Redis (password must match REDIS_URL) ---
REDIS_PASSWORD=change-me-strong
REDIS_URL=redis://:change-me-strong@redis:6379/0

# --- Auth / secrets (generate with: openssl rand -hex 32) ---
AUTH_SECRET=change-me
CREDENTIAL_SECRET=change-me           # encrypts BYOK keys — back up separately, off-host
SESSION_COOKIE_SECURE=true
INVITE_CODE=5566                      # beta registration gate

# --- LLM (BYOK — leave empty in prod) ---
ANTHROPIC_API_KEY=

# --- Web ---
WEB_ORIGIN=https://gulp.example.com
API_INTERNAL_URL=http://api:8000      # SSR fetch base + rewrite target

# --- Feeds / storage / logging ---
RSSHUB_BASE_URL=http://rsshub:1200
EXPORT_DIR=/data/exports
MEDIA_DIR=/data/media
LOG_LEVEL=INFO
