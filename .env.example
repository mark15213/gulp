# Copy to .env and fill in. The real .env is gitignored.

# --- Database / queue (match infra/docker-compose.yml) ---
DATABASE_URL=postgresql+psycopg://gulp:gulp@localhost:5432/gulp
REDIS_URL=redis://localhost:6379/0

# --- Auth (S0 Foundation) ---
AUTH_SECRET=change-me
# Session cookie is Secure in production only (HTTPS). Set true when deployed.
SESSION_COOKIE_SECURE=false
# Seeded dev account after `just migrate-up`: dev@example.com / gulp-dev-2026

# --- LLM provider (S2 Processing) ---
ANTHROPIC_API_KEY=

# --- Web client ---
NEXT_PUBLIC_API_URL=http://localhost:8000
WEB_ORIGIN=http://localhost:3000

# --- Feeds (spec 2026-07-09) ---
RSSHUB_BASE_URL=http://localhost:1200

# --- Logging ---
LOG_LEVEL=INFO
